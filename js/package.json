{
  "name": "@jailguard/jailguard",
  "version": "0.1.0",
  "description": "Pure-Rust prompt-injection detector with 1.5MB embedded ONNX model. 98.40% accuracy, p50 14ms CPU inference, prebuilt napi addons for Linux/macOS/Windows. Apache-2.0/MIT alternative to Rebuff and Lakera Guard.",
  "license": "MIT OR Apache-2.0",
  "author": "Yury Fedoseev",
  "homepage": "https://github.com/yfedoseev/jailguard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yfedoseev/jailguard.git"
  },
  "bugs": "https://github.com/yfedoseev/jailguard/issues",
  "keywords": [
    "prompt-injection",
    "prompt-injection-detection",
    "llm-security",
    "ai-security",
    "guardrails",
    "jailbreak-detection",
    "rebuff-alternative",
    "lakera-alternative",
    "onnx",
    "rust-binding",
    "napi",
    "native"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib/",
    "prebuilds/",
    "README.md",
    "LICENSE-APACHE",
    "LICENSE-MIT"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:native": "node scripts/build-native.mjs",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf lib build prebuilds"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
