{
  "name": "@jailguard/jailguard",
  "version": "0.1.0",
  "description": "Fast prompt-injection detection — Rust core, Node.js bindings",
  "license": "MIT OR Apache-2.0",
  "author": "Yury Fedoseev",
  "homepage": "https://github.com/yfedoseev/jailguard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yfedoseev/jailguard.git"
  },
  "bugs": "https://github.com/yfedoseev/jailguard/issues",
  "keywords": [
    "security",
    "llm",
    "prompt-injection",
    "jailbreak",
    "ai-safety"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib/",
    "prebuilds/",
    "README.md",
    "LICENSE-APACHE",
    "LICENSE-MIT"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:native": "node scripts/build-native.mjs",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf lib build prebuilds"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
